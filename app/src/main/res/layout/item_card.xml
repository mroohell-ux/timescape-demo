<?xml version="1.0" encoding="utf-8"?>
<com.example.timescapedemo.AspectRatioCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipToOutline="true"
    app:cardUseCompatPadding="false"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:strokeWidth="0dp">

    <!-- ConstraintLayout so bg layer doesn't affect measured height -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Pure background image. We blur/adjust it in the adapter. No glass/tint here. -->
        <ImageView
            android:id="@+id/bgImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <FrameLayout
            android:id="@+id/imageCardContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/imageCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:contentDescription="@string/image_card_content_desc"
                android:scaleType="centerCrop"/>

            <ImageView
                android:id="@+id/videoPlayOverlay"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:alpha="0.96"
                android:background="@drawable/bg_video_play_button"
                android:contentDescription="@string/video_play_icon_desc"
                android:src="@android:drawable/ic_media_play"
                android:padding="18dp"
                android:tint="@android:color/white"
                android:visibility="gone"/>

            <VideoView
                android:id="@+id/videoInlineView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/videoPlaybackControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_video_controls_glass"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/videoTitleLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/videoPlayPauseButton"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_video_play_button"
                        android:contentDescription="@string/video_play"
                        android:padding="9dp"
                        android:src="@android:drawable/ic_media_play"
                        android:tint="@android:color/white" />

                    <SeekBar
                        android:id="@+id/videoSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:max="1000"
                        android:minHeight="34dp"
                        android:progressDrawable="@drawable/video_seekbar_track"
                        android:thumb="@drawable/video_seekbar_thumb"
                        android:splitTrack="false" />

                    <TextView
                        android:id="@+id/videoTimeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00 / 00:00"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="normal" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/videoDurationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_card_count_indicator"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/videoProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:layout_gravity="bottom"
                android:indeterminate="false"
                android:max="1000"
                android:progressDrawable="@drawable/video_watch_progress"
                android:visibility="gone" />
        </FrameLayout>

        <!-- LOCAL scrim: very light, only beneath the text block for readability -->
        <View
            android:id="@+id/textScrim"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/text_scrim"
            app:layout_constraintStart_toStartOf="@id/card_content"
            app:layout_constraintEnd_toEndOf="@id/card_content"
            app:layout_constraintTop_toTopOf="@id/card_content"
            app:layout_constraintBottom_toBottomOf="@id/card_content" />

        <!-- Content drives height; LayoutManager caps to 2/3 screen -->
        <com.example.timescapedemo.MaxHeightLinearLayout
            android:id="@+id/card_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12h ago"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <LinearLayout
                android:id="@+id/titleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <ImageButton
                    android:id="@+id/buttonSpeakTitle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_title_speak"
                    android:tint="#FFFFFFFF"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/snippet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Snippet"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:ellipsize="end"/>
        </com.example.timescapedemo.MaxHeightLinearLayout>

        <FrameLayout
            android:id="@+id/handwritingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/handwritingImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:contentDescription="@string/handwriting_card_content_desc"
                android:scaleType="fitCenter"/>
        </FrameLayout>

        <ImageButton
            android:id="@+id/buttonStickyNotes"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/card_sticky_notes_content_desc"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_sticky_note_colored"
            android:tint="@color/sticky_note_icon_empty_tint"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <FrameLayout
            android:id="@+id/cardFlip3dLayer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/cardFlipFrontFace"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY" />

            <View
                android:id="@+id/cardFlipSide"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/bg_card_flip_side"
                android:visibility="gone" />

            <View
                android:id="@+id/cardFlipSeam"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="#44000000"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/cardFlipBackFace"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotationY="180"
                android:scaleType="fitXY" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.example.timescapedemo.AspectRatioCardView>
